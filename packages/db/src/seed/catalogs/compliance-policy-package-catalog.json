    "granularityByLayer": {
      "research": "Compliance packages keep full policy scope, owner, retention precedence, and launch-boundary detail for audit and review.",
      "strategic": "Upstream layers receive coarse operator posture, allowed scope, and major vetoes rather than full policy lineage.",
      "tactical": "Branch builders receive strategy and session constraints, fallback posture, and approval requirements before decision trees are compiled.",
      "execution_agent": "Only policy-safe control snapshots, active approval scope, and legality flags should remain before deterministic enforcement.",
      "training_feedback": "Replay review may refresh confidence in package applicability and review cadence inside seeded bounds without mutating hard legality."
    },
    "policyRule": "Compliance packages can narrow eligibility, alter promotion posture, or require additional approval, but they cannot be bypassed by provider output or user preference."
