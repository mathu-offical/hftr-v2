    "progressiveAccessLevels": [
      {
        "level": "overview",
        "returns": ["name", "class", "scope", "operatorPosture", "liveImpact"]
      },
      {
        "level": "analyst",
        "returns": [
          "enforcementSurfaces",
          "fallbackPaths",
          "affectedStrategies",
          "affectedSectors",
          "verificationSignals"
        ]
      },
      {
        "level": "lineage",
        "returns": [
          "policyOwner",
          "effectiveDate",
          "retentionImplications",
          "reviewCadence",
          "runtimeControlSurface"
        ]
      }
    ]
  },
