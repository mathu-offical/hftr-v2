  "crossSessionRules": {
    "extendedHoursOrderRule": "For equity extended-hours routing, only limit orders with time_in_force day or gtc are eligible and extended_hours must be true.",
    "advancedOrderRule": "Bracket, OCO, and OTO workflows are not extended-hours eligible and must route only through compatible regular-session paths.",
    "trailingStopRule": "Trailing stop orders do not trigger outside regular market hours even if they persist across sessions.",
    "agedOrderRule": "GTC orders are subject to aged-order cancellation after 90 days and remain pending_cancel until the venue confirms cancellation.",
    "lifecycleRule": "Accepted status is common outside active routing windows and must be reconciled via trade_updates and REST polling before any retry decision.",
