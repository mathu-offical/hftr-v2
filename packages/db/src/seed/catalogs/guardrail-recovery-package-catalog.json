{
  "asOf": "2026-05-19",
  "status": "in_progress",
  "purpose": "First-class guardrail and recovery package catalog used to keep deterministic failure semantics, recovery ladders, and escalation paths independently queryable instead of buried in strategy prose.",
  "querySurfaces": {
    "moduleQueries": [
      "guardrail_summary",
      "package_detail",
      "family_binding_lookup",
      "recovery_ladder_review",
      "failure_code_lookup",
      "control_surface_review"
    ],
    "progressiveAccessLevels": [
      {
        "level": "overview",
        "returns": ["name", "class", "primaryTriggers", "boundStrategies", "deterministicOutcome"]
      },
      {
        "level": "analyst",
        "returns": [
          "failureCodes",
          "recoveryLadder",
          "boundSectors",
          "escalationPath",
          "verificationSignals"
        ]
      },
      {
        "level": "lineage",
        "returns": [
          "operatorVisibility",
          "reviewCadence",
          "linkedKnowledge",
          "runtimeControlSurface"
        ]
      }
    ]
  },
  "runtimeControlSurface": {
    "weightingDrivers": [
      "failure_density",
      "liquidity_stress",
      "session_legality_state",
      "correlation_stability",
      "policy_severity"
    ],
    "boundedRangeFamilies": [
      "cooldown_window_band",
      "reprice_distance_band",
      "reentry_delay_band",
      "inventory_retreat_band"
    ],
    "granularityByLayer": {
      "research": "Guardrail packages keep full failure-code lineage, recovery order, and sector or strategy bindings for audit and promotion review.",
      "strategic": "Upstream layers receive active veto state and recovery posture without the full operational ladder.",
      "tactical": "Branch builders receive concrete recovery ladders, abort conditions, and cooldown posture before instruction compilation.",
      "execution_agent": "Only deterministic failure codes, active guardrail snapshots, and recovery-safe field constraints should remain before dispatch.",
      "training_feedback": "Replay review may recalibrate cooldowns and reprice envelopes inside seeded bounds, but failure semantics and hard blocks remain immutable."
    },
    "policyRule": "Guardrail packages can block, defer, downgrade, or reroute execution, but they may never be bypassed by provider output or discretionary interpretation below tier 3."
  },
