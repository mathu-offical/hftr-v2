{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "DATABASE_URL",
    "NODE_ENV",
    "CRON_SECRET",
    "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
    "CLERK_SECRET_KEY",
    "DEV_AUTH_BYPASS",
    "ANTHROPIC_API_KEY",
    "MISTRAL_API_KEY",
    "GROQ_API_KEY",
    "CEREBRAS_API_KEY",
    "FIREWORKS_API_KEY",
    "OPENROUTER_API_KEY",
    "ANTHROPIC_STRATEGIC_MODEL",
    "MISTRAL_TACTICAL_MODEL",
    "GROQ_EXECUTION_MODEL",
    "HFTR_LLM_MODE",
    "STRIPE_SECRET_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "ALPACA_PAPER_KEY",
    "ALPACA_PAPER_SECRET",
    "CREDENTIALS_ENCRYPTION_KEY",
    "SETTINGS_ENCRYPTION_KEY",
    "VERCEL_GIT_COMMIT_SHA",
    "VERCEL_DEPLOYMENT_ID"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    }
  }
}
