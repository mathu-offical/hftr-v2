# ── Database (required: dev, preview, prod) ─────────────────────────────────
# Neon Postgres connection string (pooled). Standard var per D-006 / TD-04.
DATABASE_URL=

# ── Auth: Clerk (required: dev, preview, prod) ──────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Dev-only bypass: active ONLY when Clerk is unconfigured AND NODE_ENV != production.
DEV_AUTH_BYPASS=

# ── Cron / queue drain protection (required: preview, prod) ─────────────────
CRON_SECRET=

# ── LLM providers ───────────────────────────────────────────────────────────
# Runtime auth uses user-saved keys only (D-027). Env keys are CI/smoke only.
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
CEREBRAS_API_KEY=
FIREWORKS_API_KEY=
OPENROUTER_API_KEY=
# Opt-in smoke: pnpm smoke:llm (node scripts/smoke-llm-providers.mjs)
HFTR_LLM_SMOKE=
# Optional model id overrides (must remain allowlisted in MODEL_CAPABILITY_REGISTRY)
ANTHROPIC_STRATEGIC_MODEL=
MISTRAL_TACTICAL_MODEL=
GROQ_EXECUTION_MODEL=
# deterministic = force placeholder handlers (CI); live = allow provider calls
HFTR_LLM_MODE=

# ── Research sources (CI/smoke only; runtime uses user_research_keys — D-039) ─
BRAVE_API_KEY=
MARKETAUX_API_KEY=
MARKET_NEWS_API_KEY=
# Opt-in smoke: pnpm smoke:research (node scripts/smoke-research-sources.mjs)
HFTR_RESEARCH_SMOKE=
FINNHUB_API_KEY=
POLYGON_API_KEY=
FRED_API_KEY=
ALPHA_VANTAGE_API_KEY=

# ── Billing: Stripe (required: M4+) ─────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Brokers (required per connected venue; M2+) ─────────────────────────────
# Users supply their own keys through the UI; these are for CI smoke tests only.
ALPACA_PAPER_KEY=
ALPACA_PAPER_SECRET=
# Opt-in smoke: pnpm smoke:alpaca-paper (node scripts/smoke-alpaca-paper.mjs)
ALPACA_PAPER_SMOKE=

# ── Secrets encryption (required: preview, prod) ────────────────────────────
# 32-byte base64/hex key for AES-GCM encryption of stored broker credentials.
CREDENTIALS_ENCRYPTION_KEY=
# 32-byte hex (64 chars) or base64 for AES-GCM of per-user LLM API keys.
# Local fallback derives from CRON_SECRET when unset (dev only).
SETTINGS_ENCRYPTION_KEY=
