{
  "asOf": "2026-05-19",
  "status": "in_progress",
  "purpose": "Seeded broker policy envelope catalog used to bind user-configurable broker behavior inside deterministic platform guard bands.",
  "querySurfaces": {
    "moduleQueries": [
      "envelope_summary",
      "throttle_profile_lookup",
      "session_compatibility_review",
      "failure_handling_review",
      "trace_requirements",
      "control_surface_review"
    ],
    "progressiveAccessLevels": [
      {
        "level": "overview",
        "returns": ["name", "modes", "routingScope", "orderWorkflowCompatibility"]
      },
      {
        "level": "analyst",
        "returns": [
          "throttleProfile",
          "timeoutProfile",
          "failureHandling",
          "platformGuardrails",
          "verificationSignals"
        ]
      },
      {
        "level": "lineage",
        "returns": ["fieldContracts", "policyRules", "runtimeControlSurface"]
      }
    ]
  },
  "runtimeControlSurface": {
    "weightingDrivers": [
      "broker_mode",
      "routing_scope_complexity",
      "transport_health_state",
      "session_compatibility",
      "policy_profile_version"
    ],
    "boundedRangeFamilies": [
      "trade_budget_band",
      "market_data_budget_band",
      "reconnect_backoff_band",
      "cooldown_window_band",
      "burst_cap_band"
    ],
    "granularityByLayer": {
      "research": "Broker envelopes keep full throttle semantics, timeout classes, failure handling, and trace requirements for policy verification and audit review.",
      "strategic": "Upstream layers receive broker-mode posture, coarse envelope compatibility, and major vetoes rather than raw transport budgets.",
      "tactical": "Branch builders receive envelope-specific workflow compatibility, cooldown posture, and transport-failure semantics before instruction compilation.",
      "execution_agent": "Only the active envelope snapshot, legality constraints, and precision-safe broker compatibility fields should remain before deterministic dispatch.",
      "training_feedback": "Replay and paper-mode review may recalibrate active envelope usage inside seeded policy classes, but platform guard bands stay immutable."
    },
    "policyRule": "Users may tune broker behavior only inside the active envelope; platform hard caps, trace requirements, and deterministic reconciliation rules remain non-bypassable."
  },
  "fieldContracts": [
    {
      "field": "tradeRequestBudgetPerMin",
      "meaning": "Max trading-endpoint request budget under the active broker envelope.",
      "freezeState": "testing_baseline_v1_not_live_signoff"
    },
    {
      "field": "marketDataRequestBudgetPerMin",
      "meaning": "Max market-data request budget under the active broker envelope.",
      "freezeState": "testing_baseline_v1_not_live_signoff"
    },
    {
      "field": "streamingSymbolBudget",
      "meaning": "Max concurrent realtime symbol budget under the active broker envelope.",
      "freezeState": "testing_baseline_v1_not_live_signoff"
    },
    {
      "field": "wsReconnectMaxAttempts",
      "meaning": "Bounded number of reconnect attempts before circuit-breaker escalation.",
      "freezeState": "testing_baseline_v1_not_live_signoff"
    },
    {
      "field": "wsReconnectBackoffMs",
      "meaning": "Reconnect pacing model, implemented as jittered exponential backoff.",
      "freezeState": "testing_baseline_v1_not_live_signoff"
    },
    {
      "field": "cooldownWindowMs",
      "meaning": "Deterministic cooldown window after repeated broker or transport failures.",
      "freezeState": "testing_baseline_v1_not_live_signoff"
    },
    {
      "field": "burstCap",
      "meaning": "Short-window request burst cap enforced ahead of sustained minute budgets.",
      "freezeState": "testing_baseline_v1_not_live_signoff"
    },
    {
      "field": "policyProfileVersion",
      "meaning": "Versioned policy identifier required in all action traces and replay logs.",
      "freezeState": "required"
    }
  ],
