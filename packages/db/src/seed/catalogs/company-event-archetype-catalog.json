      "class": "strategic_transaction",
      "freshnessWindowMin": 7200,
      "backgroundCurationPriority": "high",
      "sourcePriority": ["company_ir", "sec_filing", "exchange_notice"],
      "amplifies": ["gap_and_go", "liquidity_sweep_reversal"],
      "suppresses": ["market_making", "pullback_continuation"],
      "requiresBlackout": true,
      "reentryMode": "deal_terms_and_halt_state_confirmed",
      "verificationSignals": [
        "definitive_terms_confirmed",
        "cash_stock_mix_known",
        "deal_spread_state",
        "halt_or_resume_status"
      ],
      "invalidatesWhen": ["talks_only", "deal_terms_missing", "cross_market_conflict"]
    },
    {
      "id": "evt-007",
      "name": "management_transition_or_key_personnel_change",
      "class": "management_change",
      "freshnessWindowMin": 4320,
      "backgroundCurationPriority": "medium",
      "sourcePriority": ["company_ir", "sec_filing"],
      "amplifies": ["liquidity_sweep_reversal", "pullback_continuation"],
      "suppresses": ["market_making"],
      "requiresBlackout": false,
      "reentryMode": "leadership_materiality_scored",
      "verificationSignals": [
