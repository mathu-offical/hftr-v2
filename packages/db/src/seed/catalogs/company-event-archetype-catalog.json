  "policyRules": {
    "sourceRule": "Primary-source confirmation is required before company-event context can activate a strategy family or clear a blackout.",
    "freshnessRule": "Archetypes lose bias weight after freshnessWindowMin unless refreshed by new primary-source evidence or verified market response.",
    "blackoutRule": "When requiresBlackout is true, tactical decomposition must insert no-trade, delayed-entry, or confirmation-only branches until the blackout clears.",
    "curationRule": "Background curation may refresh reliability scores and evidence packages, but it cannot create direct execution authority."
  },
