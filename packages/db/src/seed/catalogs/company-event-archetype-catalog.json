      "amplifies": ["earnings_guidance_drift", "pullback_continuation", "gap_and_go"],
      "suppresses": ["market_making"],
      "requiresBlackout": false,
      "reentryMode": "confirmation_window_required",
      "verificationSignals": [
        "guidance_delta_direction",
        "estimate_revision_alignment",
        "volume_confirmation",
        "sector_sympathy_confirmation"
