      "freshnessWindowMin": 4320,
      "backgroundCurationPriority": "high",
      "sourcePriority": ["official_regulator_release", "court_filing", "company_ir"],
      "amplifies": ["gap_and_go", "liquidity_sweep_reversal"],
      "suppresses": ["pairs_stat_arb", "market_making"],
      "requiresBlackout": true,
      "reentryMode": "official_source_and_halt_state_confirmed",
      "verificationSignals": [
        "official_source_confirmed",
        "halt_status_clear",
        "sector_regulatory_sympathy",
        "spread_regime_check"
      ],
      "invalidatesWhen": ["rumor_only", "jurisdiction_scope_unknown"]
    },
    {
      "id": "evt-005",
      "name": "product_launch_or_platform_event",
      "class": "product",
      "freshnessWindowMin": 2880,
      "backgroundCurationPriority": "medium",
      "sourcePriority": ["company_ir", "launch_event_stream", "official_blog"],
      "amplifies": ["gap_and_go", "lead_lag_propagation", "pullback_continuation"],
      "suppresses": ["market_making"],
      "requiresBlackout": false,
      "reentryMode": "market_response_confirmation",
      "verificationSignals": [
        "launch_confirmed",
        "peer_sympathy_move",
        "relative_strength",
        "volume_concentration"
