{
  "asOf": "2026-05-29",
  "status": "in_progress",
  "purpose": "Seeded catalyst and company-event archetype catalog used to bias strategy activation, blackout handling, background curation prioritization, and event-impact graph edges.",
  "specRefs": ["event-impact-graph-spec.md", "regime-and-market-state-spec.md"],
  "querySurfaces": {
    "moduleQueries": [
      "event_summary",
      "archetype_detail",
      "strategy_impact_lookup",
      "blackout_review",
      "source_priority_review",
      "event_impact_path_lookup",
      "playbook_lookup",
      "control_surface_review"
    ],
    "progressiveAccessLevels": [
      {
        "level": "overview",
        "returns": [
          "name",
          "class",
          "freshnessWindowMin",
          "backgroundCurationPriority",
          "requiresBlackout"
        ]
      },
      {
        "level": "analyst",
        "returns": [
          "sourcePriority",
          "amplifies",
          "suppresses",
          "verificationSignals",
          "invalidatesWhen"
        ]
      },
      {
        "level": "lineage",
        "returns": ["reentryMode", "policyRules", "runtimeControlSurface"]
      }
    ]
  },
  "runtimeControlSurface": {
    "weightingDrivers": [
      "event_freshness",
      "primary_source_quality",
      "market_response_quality",
      "sector_sympathy_quality",
      "halt_and_spread_state"
    ],
    "boundedRangeFamilies": [
      "event_window_band",
      "reentry_confirmation_band",
      "source_decay_band",
      "post_halt_stability_band"
    ],
    "granularityByLayer": {
      "research": "Event packages keep full source hierarchy, invalidation logic, blackout posture, and reentry semantics for promotion and audit review.",
      "strategic": "Downstream layers receive catalyst quality, blackout posture, and dominant strategy-impact shape rather than full event lineage.",
      "tactical": "Branch builders receive event-window timing, suppression detail, source requirements, and reentry posture needed for decision-tree construction.",
      "training_feedback": "Replay loops may refresh event reliability and decay timing inside seeded archetype envelopes without mutating legality rules."
    },
    "policyRule": "Company-event archetypes may amplify, suppress, or blackout strategy paths upstream, but final legality and guardrail enforcement remain deterministic and provider-free."
  },
  "archetypes": [
    {
      "id": "evt-001",
      "name": "scheduled_earnings_release",
      "class": "earnings",
      "freshnessWindowMin": 1440,
      "backgroundCurationPriority": "high",
      "sourcePriority": ["company_ir", "exchange_calendar", "primary_transcript"],
      "amplifies": ["earnings_guidance_drift", "gap_and_go", "opening_range_breakout"],
      "suppresses": ["market_making", "pairs_stat_arb"],
      "requiresBlackout": true,
      "reentryMode": "post_release_confirmation_only",
      "verificationSignals": [
        "primary_source_confirmed",
        "calendar_match",
        "relative_volume_spike",
        "post_release_spread_normalization"
      ],
      "invalidatesWhen": [
        "release_time_uncertain",
        "trading_halt_active",
        "headline_conflict_unresolved"
      ]
    },
    {
      "id": "evt-002",
      "name": "forward_guidance_change",
      "class": "guidance",
