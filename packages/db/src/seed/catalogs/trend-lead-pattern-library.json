  "status": "in_progress",
  "purpose": "First-class trend and lead pattern library used to map market-state evidence into strategy-family nomination, variant routing, and compound handoff sequencing.",
  "querySurfaces": {
    "moduleQueries": [
      "pattern_summary",
      "pattern_detail",
      "family_binding_lookup",
      "sector_binding_lookup",
      "compound_handoff_review",
      "control_surface_review"
    ],
    "progressiveAccessLevels": [
      {
        "level": "overview",
        "returns": ["name", "class", "summary", "preferredFamilies", "sectorBindings"]
      },
      {
        "level": "analyst",
        "returns": [
          "inputs",
          "confirmationSignals",
          "suppressWhen",
          "preferredCompounds",
          "researchSupport"
        ]
      },
      {
        "level": "lineage",
        "returns": ["linkedKnowledge", "queryExamples", "reviewCadence", "runtimeControlSurface"]
      }
    ]
  },
  "runtimeControlSurface": {
    "weightingDrivers": [
      "lead_signal_quality",
      "sector_confirmation",
      "event_alignment",
      "breadth_stability",
      "session_and_broker_legality"
    ],
    "boundedRangeFamilies": [
      "leader_lag_window_band",
      "confirmation_depth_band",
      "followthrough_decay_band",
      "reentry_delay_band"
    ],
    "boundedRangeFamilyDefinitions": {
      "note": "Seeded research starting bands as min/typical/max. Full grounding and citations live in tier-lever-and-bounded-range-reference.md.",
      "leader_lag_window_band": {
        "min_ms": 2000,
        "typical_ms": 15000,
        "max_ms": 120000,
        "unit": "ms",
        "rule": "stale lag window suppresses sympathy entry"
      },
      "confirmation_depth_band": {
        "min": 1,
        "typical": 2,
        "max": 3,
        "unit": "confirmation_bars_or_signals"
      },
      "followthrough_decay_band": {
        "min_min": 5,
        "typical_min": 30,
        "max_min": 120,
        "unit": "minutes",
        "rule": "decay beyond band invalidates pattern freshness"
      },
      "reentry_delay_band": { "min_min": 1, "typical_min": 10, "max_min": 60, "unit": "minutes" }
    },
    "regimeRouterThresholds": {
      "reference": "tier-lever-and-bounded-range-reference.md",
      "hurst_trend": 0.55,
      "hurst_revert": 0.45,
      "adx_trend": 25,
      "adx_range": 20,
      "correlation_health_floor": { "min": 0.45, "typical": 0.6, "max": 0.75 },
      "rule": "patterns nominate momentum, mean-reversion, or risk-off bias from regime classification; thresholds bias nomination only and never soften legality or guardrails"
    },
    "granularityByLayer": {
      "research": "Pattern packages keep sector bindings, compound handoff logic, suppress conditions, and evidence cadence for curation and audit review.",
      "strategic": "Downstream layers receive ranked trend and lead candidates, family fit, and major veto state rather than full lineage detail.",
      "tactical": "Branch builders receive pattern-specific confirmation logic, lag windows, and recovery-sensitive variant hints.",
      "training_feedback": "Replay review may recalibrate pattern reliability and lag windows inside seeded envelopes without mutating legality or guardrail contracts."
    },
    "policyRule": "Trend and lead patterns may nominate families and compound handoffs upstream, but they cannot soften deterministic legality, verification, or guardrail enforcement."
  },
