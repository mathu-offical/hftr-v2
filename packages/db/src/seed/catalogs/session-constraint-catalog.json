{
  "asOf": "2026-05-19",
  "status": "in_progress",
  "purpose": "Seeded session constraint catalog used to enforce order-type legality, routing, and data-feed compatibility across regular, extended, and overnight equity sessions.",
  "querySurfaces": {
    "moduleQueries": [
      "session_summary",
      "legality_matrix_lookup",
      "feed_compatibility_review",
      "order_type_policy_lookup",
      "lifecycle_reconcile_review",
      "control_surface_review"
    ],
    "progressiveAccessLevels": [
      {
        "level": "overview",
        "returns": [
          "name",
          "hoursEt",
          "assetClass",
          "extendedHoursFlagRequired",
          "buyingPowerCheckBasis"
        ]
      },
      {
        "level": "analyst",
        "returns": [
          "orderTypeMatrix",
          "assetEligibility",
          "marketDataFeeds",
          "specialRules",
          "verificationSignals"
        ]
      },
      {
        "level": "lineage",
        "returns": ["crossSessionRules", "runtimeControlSurface"]
      }
    ]
  },
  "runtimeControlSurface": {
    "weightingDrivers": [
      "session_clock_state",
      "asset_eligibility",
      "feed_availability",
      "spread_and_liquidity_state",
      "broker_policy_compatibility"
    ],
    "boundedRangeFamilies": [
      "session_spread_ceiling_band",
      "order_legality_band",
      "feed_freshness_band",
      "reconcile_timeout_band"
    ],
    "granularityByLayer": {
      "research": "Session packages keep the full legality matrix, feed choices, lifecycle caveats, and cross-session rules for audit and policy verification.",
      "strategic": "Upstream layers receive coarse session posture, asset-class eligibility, and major routing vetoes instead of full order-type matrices.",
      "tactical": "Branch builders receive session-specific legality, feed, and queue-or-dispatch rules needed to construct compatible decision trees.",
      "execution_agent": "Only the active session legality snapshot, feed selection, and route-compatible order fields should remain before deterministic enforcement.",
      "training_feedback": "Replay review may recalibrate session-specific timing and feed assumptions inside seeded bounds without mutating hard legality rules."
    },
    "policyRule": "Session packages decide legality and routing compatibility upstream, but final order-form enforcement and broker legality checks remain deterministic at dispatch time."
  },
