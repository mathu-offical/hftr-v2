# ── Database (required: dev, preview, prod) ─────────────────────────────────
# Neon Postgres connection string (pooled). Standard var per D-006 / TD-04.
DATABASE_URL=

# ── Auth: Clerk (required: dev, preview, prod) ──────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Dev-only bypass: active ONLY when Clerk is unconfigured AND NODE_ENV != production.
DEV_AUTH_BYPASS=

# ── Cron / queue drain protection (required: preview, prod) ─────────────────
CRON_SECRET=

# ── LLM providers (required for pipeline tiers; app boots without them) ─────
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
# Optional model overrides (defaults in packages/llm/src/models.ts)
ANTHROPIC_STRATEGIC_MODEL=
MISTRAL_TACTICAL_MODEL=
GROQ_EXECUTION_MODEL=

# ── Billing: Stripe (required: M4+) ─────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Brokers (required per connected venue; M2+) ─────────────────────────────
# Users supply their own keys through the UI; these are for CI smoke tests only.
ALPACA_PAPER_KEY=
ALPACA_PAPER_SECRET=

# ── Secrets encryption (required: preview, prod) ────────────────────────────
# 32-byte base64 key for AES-GCM encryption of stored broker credentials.
CREDENTIALS_ENCRYPTION_KEY=
